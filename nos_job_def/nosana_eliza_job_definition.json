{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "cli"
  },
  "ops": [
    {
      "type": "container/run",
      "id": "axiom-agent",
      "args": {
        "image": "ghcr.io/marchantdev/agent-challenge:latest",
        "expose": 8080,
        "env": {
          "OPENAI_API_KEY": "YOUR_GROQ_API_KEY",
          "OPENAI_BASE_URL": "https://api.groq.com/openai/v1",
          "OPENAI_SMALL_MODEL": "llama-3.3-70b-versatile",
          "OPENAI_LARGE_MODEL": "llama-3.3-70b-versatile",
          "SERVER_PORT": "3000",
          "FRONTEND_PORT": "8080",
          "NODE_ENV": "production"
        }
      }
    }
  ]
}
