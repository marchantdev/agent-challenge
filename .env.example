# ─── Nosana GPU Inference ────────────────────────────────────────────────────
# Nosana-hosted LLM endpoint
OPENAI_API_URL=https://4ksj3tve5bazqwkuyqdhwdpcar4yutcuxphwhckrdxmu.node.k8s.prd.nos.ci/v1

# Model name served at the Nosana inference endpoint
MODEL_NAME=Qwen/Qwen3.5-4B

# ─── Embedding Configuration ────────────────────────────────────────────────
OPENAI_EMBEDDING_URL=https://4yiccatpyxx773jtewo5ccwhw1s2hezq5pehndb6fcfq.node.k8s.prd.nos.ci/v1
OPENAI_EMBEDDING_API_KEY=nosana
OPENAI_EMBEDDING_MODEL=Qwen3-Embedding-0.6B
OPENAI_EMBEDDING_DIMENSIONS=1024

# ─── API Keys ────────────────────────────────────────────────────────────────
# Etherscan V2 API key — free at https://etherscan.io/register
# Used for contract source code verification and ABI lookups
ETHERSCAN_API_KEY=

# Optional: Solana RPC endpoint (defaults to public mainnet-beta if not set)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ─── ElizaOS Runtime ─────────────────────────────────────────────────────────
# ElizaOS requires an OPENAI_API_KEY env var (used as the auth header for
# the OPENAI_API_URL above). Set to any non-empty value for Nosana inference.
OPENAI_API_KEY=nosana

# ─── Agent Settings ──────────────────────────────────────────────────────────
# Port for the ElizaOS agent runtime (default: 3000)
SERVER_PORT=3000

# Port for the Axiom React frontend server (default: 8080)
FRONTEND_PORT=8080

# ─── Nosana Deployment ───────────────────────────────────────────────────────
# Nosana wallet private key (base58) — used by CI/CD to post the job.
# Only required in GitHub Actions. Never commit a real key.
NOSANA_PRIVATE_KEY=

# Nosana node ID — injected automatically when running on Nosana infrastructure.
# Set manually for local testing if desired.
NOSANA_NODE_ID=local
